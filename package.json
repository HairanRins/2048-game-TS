{
  "name": "2048-game-ts",
  "version": "1.0.0",
  "description": "2048 game built with modern TypeScript architecture",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && cp -r dist/* public/ && find public -type f -name '*.d.ts' -delete && find public -type f -name '*.map' -delete",
    "dev": "tsc --watch",
    "serve": "npx http-server public -p 8080 -c-1",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/**/*.ts",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@typescript-eslint/eslint-plugin": "^5.57.0",
    "@typescript-eslint/parser": "^5.57.0",
    "eslint": "^8.37.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "2048",
    "game",
    "typescript",
    "architecture"
  ],
  "author": "Rin's Andrianina",
  "license": "MIT"
}